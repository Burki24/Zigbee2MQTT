    "caption": "Brightness with Transition",
    "form": [
        "$id = IPS_GetObjectIDByIdent('brightness', $_IPS['TARGET']);",
        "return [",
        "   [",
        "       'type' => 'SelectValue',",
        "       'name' => 'Brightness',",
        "       'caption' => 'Brightness Variable',",
        "       'variableID' => $id",
        "   ],",
        "   [",
        "       'type' => 'NumberSpinner',",
        "       'name' => 'TransitionTime',",
        "       'caption' => 'Transition Time',",
        "       'minimum' => 0,",
        "       'suffix' => 'seconds'",
        "   ]",
        "];"
    ],
    "priority": 1,
    "category": "target",
    "action": [
        "Z2M_SendSetCommand($_IPS['TARGET'], ['brightness' => (int)($_IPS['Brightness']*254/100), 'transition' => $_IPS['TransitionTime']]);"
